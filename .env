# --- Pub/Sub Emulator ---
# The Google client library reads PUBSUB_EMULATOR_HOST automatically
PUBSUB_EMULATOR_HOST=localhost:8085
PUBSUB_PROJECT_ID=local-project
PUBSUB_TOPIC_ID=cdc-events
PUBSUB_SUBSCRIPTION_ID=cdc-pipeline-sub

# --- GCS (fake-gcs-server) ---
STORAGE_EMULATOR_HOST=http://localhost:4443
GCS_BUCKET_NAME=pdf-pipeline-bucket
GCS_PROJECT_ID=local-project

# --- Redis (taskiq broker) ---
REDIS_URL=redis://localhost:6379/0

# --- PDF source directory ---
PDFS_DIR=pdfs
